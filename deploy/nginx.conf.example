# /etc/nginx/sites-available/marketpulse — 示例，请替换 server_name 与证书路径

upstream marketpulse_api {
    server 127.0.0.1:8080;
    keepalive 8;
}

server {
    listen 443 ssl http2;
    server_name marketpulse.example.com;

    # ssl_certificate     /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;

    root /var/www/marketpulse;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://marketpulse_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 头像等本地上传文件由 marketd 托管（upload.dir / public_path）
    location /uploads/ {
        proxy_pass http://marketpulse_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # 浏览器长期缓存；换图时文件名含 hash，可放心 cache
        proxy_hide_header Cache-Control;
        add_header Cache-Control "public, max-age=604800" always;
    }

    location /healthz {
        proxy_pass http://marketpulse_api;
    }

    location /ws/ {
        proxy_pass http://marketpulse_api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 3600s;
    }
}
