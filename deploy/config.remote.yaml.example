# 远程生产配置模板 — 由 deploy-remote.sh 根据 deploy.local.yaml 生成并上传

app:
  addr: "0.0.0.0:8080"
  mode: "release"
  log_dir: "log"
  # 相对 remote_dir，与 web/dist 同步目录对应
  static_dir: "web/dist"

cors:
  allowed_origins: []

symbols:
  - BTC
  - ETH
  - BNB
  - LTC
  - FIL

alpha:
  enabled: true
  provider: bitget
  product_type: USDT-FUTURES
  quote_asset: USDT
  poll_interval: 30s
  resolve_interval: 10m
  indices:
    - id: qqq
      name: 纳指ETF
      symbol: QQQUSDT
    - id: spy
      name: 标普ETF
      symbol: SPYUSDT
  stocks:
    - id: aapl
      name: 苹果
      symbol: AAPLUSDT
    - id: msft
      name: 微软
      symbol: MSFTUSDT
    - id: nvda
      name: 英伟达
      symbol: NVDAUSDT
    - id: amzn
      name: 亚马逊
      symbol: AMZNUSDT
    - id: googl
      name: 谷歌
      symbol: GOOGLUSDT
    - id: meta
      name: META
      symbol: METAUSDT
    - id: tsla
      name: 特斯拉
      symbol: TSLAUSDT

ingest:
  binance:
    # 国内云主机若 stream.binance.com 连不上，可改用仅行情镜像：
    # ws_base: "wss://data-stream.binance.vision/stream"
    ws_base: "wss://stream.binance.com:9443/stream"
  otc:
    usdt_cny_interval: 30s
  forex:
    usd_cny_interval: 1h
  equity:
    interval: 60s
    providers:
      - tencent
      - eastmoney
    index_ids:
      - sh000001
      - sz399001
      - sz399006
      - sh000688
      - hsi
      - n225
      - ks11
      - dji
      - ixic
      - gspc
      - gold
      - silver
      - crude
  macro:
    interval: 5m
