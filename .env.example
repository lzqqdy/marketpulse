# 复制为 .env 后按需修改（.env 已 gitignore）
MARKETPULSE_PORT=8080

# 使用 --profile db 时一并开启连接
MYSQL_ENABLED=false
REDIS_ENABLED=false

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=marketpulse
MYSQL_USER=marketpulse
MYSQL_PASSWORD=marketpulse
MYSQL_PORT=3306

REDIS_PASSWORD=
REDIS_DB=0
REDIS_PORT=6379

# 用户中心（需 MYSQL_ENABLED=true REDIS_ENABLED=true）
USERS_ENABLED=false
USERS_SEED_PHONE=
USERS_SEED_PASSWORD=
USERS_SEED_NAME=管理员

# 资产中心（需 MYSQL_ENABLED=true 且 USERS_ENABLED=true）
PORTFOLIO_ENABLED=false
